<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="HelloController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER">
        <Button text="EN" onAction="#onENClick"/>
        <Button text="FR" onAction="#onFRClick"/>
        <Button text="JP" onAction="#onJPClick"/>
        <Button text="IR" onAction="#onIRClick"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="lblDistance" text="%distance.label" prefWidth="120"/>
        <TextField fx:id="txtDistance" promptText="0"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="lblFuel" text="%fuel.label" prefWidth="120"/>
        <TextField fx:id="txtFuel" promptText="0"/>
    </HBox>

    <Button fx:id="btnCalculate" text="%calculate.button" onAction="#onCalculateClick"/>

    <Label fx:id="lblResult" text="%result.default" wrapText="true"/>
</VBox>